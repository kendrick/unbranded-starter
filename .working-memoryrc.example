# working-memory-kit configuration (optional).
# Copy or rename to .working-memoryrc and commit it to share team-level overrides.
# Per-developer env vars (WORKING_MEMORY_MAX_LINES, WORKING_MEMORY_FILE_THRESHOLD,
# WORKING_MEMORY_LINE_THRESHOLD) take precedence over this file.

# How many non-empty lines activeContext.md may grow to before SessionStart
# warns. The spec's hard limit is 20. Higher values give more queue room at
# the cost of larger session-start context.
MAX_ACTIVE_CONTEXT_LINES=20

# Files changed in the working tree before Stop nudges you to update working memory.
NUDGE_FILE_THRESHOLD=5

# OR total inserted+deleted lines before the same nudge fires. Catches single-
# file refactors that file count would miss.
NUDGE_LINE_THRESHOLD=200

# --- alternative presets ---
# Uncomment one block to opt in. Comment out the defaults above first.

# preset: strict — frequent updates, tighter discipline.
# Good for early-stage projects iterating on architecture weekly.
# MAX_ACTIVE_CONTEXT_LINES=15
# NUDGE_FILE_THRESHOLD=3
# NUDGE_LINE_THRESHOLD=100

# preset: loose — mature codebase, less context churn.
# Good when most work is incremental and constant nudges become noise.
# MAX_ACTIVE_CONTEXT_LINES=40
# NUDGE_FILE_THRESHOLD=10
# NUDGE_LINE_THRESHOLD=500

# --- coexistence with external spec-driven tooling ---
# The installer writes these when you pass --coexist-with / --no-coexist; you can
# also set them by hand. Same bare key="value" form (no spaces around =).

# Path to spec-driven tooling the kit should stay out of the way of (or false to
# opt out). The installer cross-references it from the fenced AGENTS.md section.
# external_spec_tooling="docs/specs"

# Optional: that tool's principles/standards file. conventions.md is pointed here.
# external_spec_principles="docs/specs/STANDARDS.md"

# Set to true once you've answered, so the installer stops suggesting --coexist-with.
# coexistence_asked=true
