{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"release-type": "node",
	"include-component-in-tag": false,
	"bump-minor-pre-major": true,
	"packages": {
		".": {
			"extra-files": [
				{ "type": "json", "path": "create-unbranded/package.json", "jsonpath": "$.version" },
				{ "type": "json", "path": "create-unbranded/package.json", "jsonpath": "$.dependencies.unbranded" }
			]
		}
	}
}
