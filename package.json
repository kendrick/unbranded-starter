{
	"name": "unbranded",
	"type": "module",
	"version": "0.7.0",
	"packageManager": "pnpm@10.0.0",
	"description": "Interactive CLI to scaffold your preferred project tooling into any project, using your existing package manager.",
	"author": "Kendrick Arnett",
	"license": "MIT",
	"homepage": "https://github.com/kendrick/unbranded-starter#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kendrick/unbranded-starter.git"
	},
	"bugs": "https://github.com/kendrick/unbranded-starter/issues",
	"keywords": [
		"scaffold",
		"scaffolding",
		"cli",
		"generator",
		"boilerplate",
		"starter",
		"project-setup",
		"developer-tools",
		"eslint",
		"typescript",
		"tailwindcss",
		"vitest",
		"stylelint",
		"package-manager"
	],
	"exports": {
		".": "./dist/cli.js"
	},
	"bin": {
		"unbranded": "./dist/cli.js"
	},
	"files": [
		".editorconfig",
		"AGENTS.md",
		"dist",
		"docs",
		"eslint.config.mjs",
		"opt-in",
		"postcss.config.mjs",
		"schemas",
		"stylelint.config.mjs",
		"templates",
		"tsconfig.base.json",
		"vitest.config.ts"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"prepublishOnly": "pnpm build",
		"prepare": "simple-git-hooks",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "pnpm build && vitest run --config vitest.e2e.config.ts",
		"test:all": "pnpm test && pnpm test:e2e",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . && stylelint \"**/*.css\" --allow-empty-input",
		"lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix --allow-empty-input"
	},
	"dependencies": {
		"@clack/core": "1.3.1",
		"@clack/prompts": "1.4.0",
		"diff": "9.0.0",
		"node-diff3": "3.2.1"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.2.0",
		"@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
		"@eslint-react/eslint-plugin": "^3.0.0",
		"@next/eslint-plugin-next": "^15.1.0",
		"@tailwindcss/postcss": "^4.0.0",
		"@types/node": "^22.10.5",
		"ajv": "8.20.0",
		"eslint": "^9.18.0",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react-refresh": "^0.5.2",
		"jsdom": "^25.0.1",
		"lint-staged": "^17.0.8",
		"simple-git-hooks": "^2.13.1",
		"stylelint": "^17.0.0",
		"stylelint-config-standard": "^40.0.0",
		"tailwindcss": "^4.0.0",
		"tsup": "^8.5.1",
		"typescript": "^5.7.0",
		"vitest": "^2.1.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged",
		"pre-push": "CI=true pnpm lint"
	},
	"lint-staged": {
		"*": "eslint --fix",
		"*.css": "stylelint --fix"
	}
}
