{
	"name": "unbranded",
	"type": "module",
	"version": "0.1.0",
	"packageManager": "pnpm@10.0.0",
	"description": "Interactive CLI to scaffold your preferred project tooling into any project, using your existing package manager.",
	"author": "Kendrick Arnett",
	"license": "MIT",
	"exports": {
		".": "./dist/cli.js"
	},
	"bin": {
		"unbranded": "./dist/cli.js"
	},
	"files": [
		".editorconfig",
		".nvmrc",
		"dist",
		"eslint.config.mjs",
		"opt-in",
		"postcss.config.mjs",
		"stylelint.config.mjs",
		"templates",
		"tsconfig.base.json",
		"vitest.config.ts"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"prepublishOnly": "pnpm build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "pnpm build && vitest run --config vitest.e2e.config.ts",
		"test:all": "pnpm test && pnpm test:e2e",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . && stylelint \"**/*.css\" --allow-empty-input",
		"lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix --allow-empty-input"
	},
	"dependencies": {
		"@clack/prompts": "1.4.0",
		"diff": "9.0.0"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.2.0",
		"@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
		"@eslint-react/eslint-plugin": "^3.0.0",
		"@next/eslint-plugin-next": "^15.1.0",
		"@tailwindcss/postcss": "^4.0.0",
		"@types/node": "^22.10.5",
		"eslint": "^9.18.0",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react-refresh": "^0.5.2",
		"jsdom": "^25.0.1",
		"stylelint": "^17.0.0",
		"stylelint-config-standard": "^40.0.0",
		"tailwindcss": "^4.0.0",
		"tsup": "^8.5.1",
		"typescript": "^5.7.0",
		"vitest": "^2.1.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild"]
	}
}
