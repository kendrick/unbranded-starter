{
	"name": "unbranded-starter",
	"version": "0.1.0",
	"private": true,
	"description": "Personal project starter — @antfu eslint, stylelint, strict TS, Tailwind v4. Fork to begin a new project.",
	"engines": {
		"node": ">=22",
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@10.0.0",
	"type": "module",
	"scripts": {
		"dev": "echo 'Edit this script for your framework. e.g. next dev, vite, tsup --watch'",
		"build": "echo 'Edit this script for your framework'",
		"preview": "echo 'Edit this script for your framework'",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . && stylelint \"**/*.css\" --allow-empty-input",
		"lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix --allow-empty-input"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.2.0",
		"@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
		"@next/eslint-plugin-next": "^15.1.0",
		"@tailwindcss/postcss": "^4.0.0",
		"@types/node": "^22.10.5",
		"eslint": "^9.18.0",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"jsdom": "^25.0.1",
		"stylelint": "^17.0.0",
		"stylelint-config-standard": "^40.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.8"
	}
}
