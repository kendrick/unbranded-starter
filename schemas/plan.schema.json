{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/kendrick/unbranded-starter/schemas/plan.schema.json",
	"title": "unbranded --dry-run --json",
	"description": "What a run would do, as data: the resolved unit set (with implied additions in `auto`), the detected package manager, and a per-file verdict. Nothing is written.",
	"type": "object",
	"required": ["schema", "target", "pm", "units", "auto", "files"],
	"additionalProperties": false,
	"properties": {
		"schema": { "type": "integer" },
		"target": {
			"type": "object",
			"required": ["dir", "mode"],
			"additionalProperties": false,
			"properties": {
				"dir": { "type": "string" },
				"mode": { "enum": ["new", "augment"] }
			}
		},
		"pm": { "enum": ["npm", "pnpm", "yarn", "bun", null] },
		"units": { "type": "array", "items": { "type": "string" } },
		"auto": { "type": "array", "items": { "type": "string" } },
		"files": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["path", "action"],
				"additionalProperties": false,
				"properties": {
					"path": { "type": "string" },
					"action": { "enum": ["create", "merge", "append", "skip", "conflict"] }
				}
			}
		}
	}
}
